function containsSpecialChars(str) {
       const specialChars =
         /[`!@#$%^&*()+\-=\[\]{};':"\\|,.<>\/?~]/;
       if (specialChars.test(str)){   
         return;
       } else {
         return str;
       }
}

async function sendData(url, httpMethod, bodyData) {

	var response = await fetch(url,{
                     method: httpMethod,
                     body: bodyData,
                     headers: {
                       "content-Type": "application/json",
                       }
		}

	);

	if (!response.ok) {
		throw new Error(`HTTP error! status: ${response.status}`);
	}
	var text = await response.text();
	if (!text) {
		throw new Error('Empty response from rate API');
	}
	var data;
	try {
		data = JSON.parse(text);
	} catch (e) {
		throw new Error('Invalid JSON from rate API');
	}

       return data;

}

