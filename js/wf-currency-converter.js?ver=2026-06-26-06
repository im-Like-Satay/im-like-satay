/**
 * Send selector
 */
function openCurrencySelectorSend(){

    const currencyOptionsRecieve = document.getElementById("currency-options--receive");

    var classTest = currencyOptionsRecieve.classList.contains("open");

    if(classTest){
        currencyOptionsRecieve.classList.remove('open');
        $('#currency-selector--receive').parents('.cc-money-input').removeClass('red_border');
        $('.currency-option--receieve').removeClass('focused');

        $('#currency-options-search--receive').val('');
        filterFunctionReceive();
    }

    const currencyOptionsSend = document.getElementById("currency-options--send");

    var classTest = currencyOptionsSend.classList.contains("open");

    if(classTest){
        currencyOptionsSend.classList.remove('open');
        $('#currency-selector--send').parents('.cc-money-input').removeClass('red_border');

        $('.currency-option--send').removeClass('focused');
    } else {
        currencyOptionsSend.classList.add('open');
        $('#currency-selector--send').parents('.cc-money-input').addClass('red_border');
    }

    $('#currency-options-search--send').focus();
}


