/**
 * Sell Currency
 */
const sendCurrencyOptions = document.querySelectorAll('.currency-option--send');
sendCurrencyOptions.forEach(sendCurrencyOption => {
    sendCurrencyOption.addEventListener('click', function handleClick(event) {

        let getSendAmount = removeCommas(sendAmount.value);
        let sendCurrencySelected = sendCurrencyOption.getAttribute('data-currency').toLowerCase();
        let receiveCurrencySelect = document.getElementById('currency-selector--receive').getAttribute('data-currency').toLowerCase();
        const sendCurrencyParentSlug = sendCurrencyOption.getAttribute('data-parent-slug').toLowerCase();

        event.preventDefault();

        // Don't do anything if the current currency is selected
