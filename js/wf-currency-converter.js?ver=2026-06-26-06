$(document).on('keydown', '.currency-options', function (event) {
    var dropdown = $(this);
    var focused_option = $($(this).find('.currency-items-wrapper .currency-option--send:focus')[0] || $(this).find('.currency-items-wrapper .currency-option--receieve:focus')[0]);
    var visible_options = dropdown.find('.currency-items-wrapper .currency-option--send:visible, .currency-items-wrapper .currency-option--receieve:visible'); // Get only the visible options

    // Space or Enter
    // if (event.keyCode == 32 || event.keyCode == 13) {
    if (event.keyCode == 13) {
        if (dropdown.hasClass('open')) {
            let clickEvent = new MouseEvent( 'click', {
                bubbles: true,
                cancelable: true
            });
            if(focused_option.length>0) {
                focused_option[0].dispatchEvent(clickEvent);
            }
        }
        return false;
        // Down
    } else if (event.keyCode == 40) {
        if (!dropdown.hasClass('open')) {
            dropdown.trigger('click');
        } else {
            var next_option = focused_option.nextAll('.currency-option--send:visible, .currency-option--receieve:visible').first();
            if (next_option.length === 0) {
                next_option = visible_options.first();
            }
            focused_option.removeClass('focused');
            next_option.addClass('focused');
            next_option.focus();
        }
        return false;
        // Up
    } else if (event.keyCode == 38) {
        if (!dropdown.hasClass('open')) {
            dropdown.trigger('click');
        } else {
            var prev_option = focused_option.prevAll('.currency-option--send:visible, .currency-option--receieve:visible').first();
            if (prev_option.length === 0) {
                prev_option = visible_options.last();
            }
            focused_option.removeClass('focused');
            prev_option.addClass('focused');
            prev_option.focus();
        }
        return false;
        // Esc
    } else if (event.keyCode == 27) {
        if (dropdown.hasClass('open')) {
            dropdown.trigger('click');
        }
        return false;
    }
});













