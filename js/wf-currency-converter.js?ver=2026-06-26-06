/**
 * Close the dropdown if the user clicks outside of it
 */

document.addEventListener("click", function(event){
    if(!event.target.matches('.dropbtn-span, .dropbtn-img, .cc-dropbtn, .currency-option--send, .currency-option--receieve, .currency-options-search')){

        let closeReceiveMenu = document.getElementById("currency-options--receive");
        let closeSendMenu = document.getElementById("currency-options--send");

        if(closeSendMenu.classList.contains('open') ){
            closeSendMenu.classList.remove('open');
            clearSearchS();
        }

        if(closeReceiveMenu.classList.contains('open') ){
            closeReceiveMenu.classList.remove('open');
            clearSearchR();
        }

        let clearSearchSend = document.getElementById("currency-options-search--send");
        clearSearchSend.value = "";

        let clearSearchReceive = document.getElementById("currency-options-search--receive");
        clearSearchReceive.value = "";
        $('.cc-money-input').removeClass('red_border');
        $('.currency-option--send').removeClass('focused');
        $('.currency-option--receieve').removeClass('focused');
        $('#currency-options-search--send, #currency-options-search--receive').val('');
        filterFunction();
        filterFunctionReceive();
    }


});


