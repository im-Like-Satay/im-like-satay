/**
 * Page Redirect/ Reload Function
 */
function redirectToNewUrl(newPath, sendCurrencySelected, receiveCurrencySelect, getSendAmount, sendCurrencyParentSlug) {
    let url = window.location.href;
    if(isSinglePage)
    {
        let urlParts = url.split('/');
        let updatedPath = urlParts.slice(0, urlParts.length - newPath).join('/') + '/';

        // Create the new URL structure
        let newUrl = updatedPath + sendCurrencyParentSlug + '/' + sendCurrencySelected + '-' + receiveCurrencySelect + '/';

        // Add the send and receive parameters
        newUrl += '?send=' + sendCurrencySelected + '&receive=' + receiveCurrencySelect + '&amount=' + getSendAmount;

        // 如果设置了isRedirect就重载页面
        if(typeof isRedirect !== 'undefined') {
            window.location = newUrl;
        }else{
            changeRateData(url.split('?')[0], sendCurrencySelected, receiveCurrencySelect, getSendAmount, newPath);
        }
    }else
    {
        let claenurl = url.split('?')[0];

        // 如果设置了isRedirect就重载页面
        if(typeof isRedirect !== 'undefined') {
            window.location=claenurl + '?send='+sendCurrencySelected + '&receive=' + receiveCurrencySelect + '&amount='+getSendAmount;
        }else{
            changeRateData(claenurl, sendCurrencySelected, receiveCurrencySelect, getSendAmount, newPath);
        }
    }

}

function changeRateData(claenurl, sendCurrencySelected, receiveCurrencySelect, getSendAmount, newPath) {
    // 修改当前url路径
    let redirectUrl = claenurl + '?send='+sendCurrencySelected + '&receive=' + receiveCurrencySelect + '&amount='+getSendAmount;
    window.history.replaceState({},"",redirectUrl);

    // 判断是否可以兑换
    let beSvg = '<svg xmlns="http://www.w3.org/2000/svg" height="1em" viewBox="0 0 384 512"><!--! Font Awesome Free 6.4.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license (Commercial License) Copyright 2023 Fonticons, Inc. --><path d="M342.6 150.6c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L192 210.7 86.6 105.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3L146.7 256 41.4 361.4c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0L192 301.3 297.4 406.6c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L237.3 256 342.6 150.6z"/></svg>';
    if(!checkPairs(sendCurrencySelected,receiveCurrencySelect,newPath)){
        let currencyPairsError = document.getElementById("currency-pairs-error");
        if(currencyPairsError=="" || !currencyPairsError) {
            let currency_pairs_error = '<div id="currency-pairs-error"><span class="pairs-warnings">' + beSvg + '</span><p>Sorry, we currently do not support this pairing at this time.</p></div>';
            
            let parent = document.querySelector('.cc-module-wrap');
            if(parent) {
                let calculator = document.querySelector('.cc-calculator');
                calculator.insertAdjacentHTML('afterend', currency_pairs_error);
                let loader = document.getElementById("loading");
                let xrBuyAmount = document.getElementById("xr-buy-amount");
                let ccexRate = document.querySelector(".ccex-rate");
                let ccDisclaimer = document.querySelector(".cc-disclaimer");

                loader.classList.remove("display");
                xrBuyAmount.classList.remove("hidden");
                ccexRate.classList.add("c-grey");
                ccDisclaimer.style.display = "none";
                document.getElementById("receive-input").value = "0.00";
                document.getElementById("xr-buy-amount").textContent= "0.00";

                let pairError = document.querySelector('.pairs-warnings svg');

                if( pairError ) {
                    pairError.addEventListener("click", function(event){
                        document.getElementById("currency-pairs-error").remove();
                    });
                }
            }
        }
    }else{
        // 存在币种对
        let currencyPairsError = document.getElementById("currency-pairs-error");
        if(currencyPairsError) {
            currencyPairsError.remove();
        }
        let parent = document.querySelector('.cc-module-wrap');
        if(parent) {
            let secondChild = parent.children[0];
            if(secondChild) {
                let ccexRate = document.querySelector(".ccex-rate");
                let ccDisclaimer = document.querySelector(".cc-disclaimer");

                ccexRate.classList.remove("c-grey");
                ccDisclaimer.style.display = "block";
            }
        }
    }

    // 修改currency-option--receive
    let pairsArrayList = localStorage.getItem('__pairsArray');
    let receiveArr = [];
    if(pairsArrayList !== null) {
        let pairsArrayArray = JSON.parse(pairsArrayList);
        let filteredStr = sendCurrencySelected.toUpperCase() + " to ";
        let filteredList = pairsArrayArray.filter(item => item.startsWith(filteredStr));
    
        filteredList.map(item => {
            let match = item.match(/to\s(\w+)$/);
            if (match) {
                receiveArr.push(match[1]); // 返回匹配到的最后一个字符
            }
        })
    }

    var outputHtml = '';
    receiveArr.forEach((item, index) => {
        var sendEle = document.querySelector('.currency-option--send[data-currency="'+ item +'"]');
        if(sendEle) {
            // 处理receive的国旗列表
            outputHtml += '<a class="currency-option--receieve" href="javascript:void(0);" data-currency="' + item +'">';
            outputHtml += '<img decoding="async" src="'+ getFlagUrl(item) + '" class="flag-img" alt="'+ item +'">' + item;
            outputHtml += '<span class="cc-country-name">'+ sendEle.querySelector('.cc-country-name').textContent +'</span>';
            outputHtml += '</a>\n';
        }
        
    })
    var receiveParentDiv = document.getElementById('currency-options--receive').querySelector('.currency-items-wrapper');
    receiveParentDiv.innerHTML= outputHtml;


    // 重新绑定事件
    let receiveCurrencyOptions = document.querySelectorAll('.currency-option--receieve');
    receiveCurrencyOptions.forEach(receiveCurrencyOption => {
        receiveCurrencyOption.addEventListener('click', function handleClick(event) {

            let getSendAmount = removeCommas(sendAmount.value);
            let recieveCurrencySelected = receiveCurrencyOption.getAttribute('data-currency').toLowerCase();
            let sendCurrencySelected = document.getElementById('currency-selector--send').getAttribute('data-currency').toLowerCase();

            event.preventDefault();

            // Don't do anything if the current currency is selected
            let ccQueryString = window.location.search;
            let ccUrlParams = new URLSearchParams(ccQueryString);
            let buyCurrencyParams = ccUrlParams.get('receive');
            if(buyCurrencyParams == recieveCurrencySelected){
                return;
            }

            redirectToNewUrl(2, sendCurrencySelected, recieveCurrencySelected, getSendAmount);
        });
    });
    // end 重新绑定事件

    // 修改选中国家
    setFlagData(sendCurrencySelected,receiveCurrencySelect,newPath);
    

    // 修改汇率
    let hasCurrencyPairsError = document.getElementById('currency-pairs-error');

    if (!hasCurrencyPairsError) {
        _rateListenersBound = false;
        buildCallData();
        (async function() {
            try {
                const currentInquiry = await getInquiry;
                if (currentInquiry && currentInquiry.rateList && currentInquiry.rateList[0]) {
                    applyRateAndBindListeners(currentInquiry.rateList[0].rate);
                }
            } catch (e) {
                if (window.console && window.console.error) {
                    console.error('Currency converter rate error:', e);
                }
            }
        })();
    }


}

function getFlagUrl(currency) {
    let selector_send_img_src = document.getElementById('currency-selector--send').querySelector('img').src;
    let selector_send_img_src_arr = selector_send_img_src.split("/-_");
    let svg_img_src='';
    if(selector_send_img_src_arr.length>0) {
        svg_img_src = selector_send_img_src_arr[0]+ '/-_' + currency + '.svg';
    }

    return svg_img_src;
}

function checkPairs(sendCurrencySelected,receiveCurrencySelect,newPath) {
    let __pairsArray = JSON.parse(localStorage.getItem('__pairsArray'));
    let send_receive = sendCurrencySelected.toUpperCase() + ' to ' + receiveCurrencySelect.toUpperCase();
    if(__pairsArray !== null && __pairsArray.includes(send_receive)) {
        return true;
    }else{
        return false;
    }

}

