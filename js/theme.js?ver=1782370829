function toggleMobileMenu() {
  const menu = document.getElementById("mobileMenu");
  const body = document.body;
  
  if (menu) {
    menu.classList.toggle("open");
    body.classList.toggle("mobile-menu-open");
  }

  // Always collapse any open submenu groups when toggling the mobile menu
  var openGroups = document.querySelectorAll(".menu-group-container.open");
  openGroups.forEach(function (g) {
    g.classList.remove("open");
  });
}

function initMobileMenu() {
  const toggleBtn = document.getElementById('mobileMenuToggle');
  if (toggleBtn) {
    // Remove any existing listeners to avoid duplicates if re-run
    const newBtn = toggleBtn.cloneNode(true);
    toggleBtn.parentNode.replaceChild(newBtn, toggleBtn);
    
    newBtn.addEventListener('click', function(e) {
      e.preventDefault();
      toggleMobileMenu();
    });
  }

  // Submenu handling
  const menuItems = document.querySelectorAll('.mobile-menu-item[data-target]');
  menuItems.forEach(item => {
    item.addEventListener('click', function(e) {
      e.preventDefault();
      const targetId = this.getAttribute('data-target');
      const submenu = document.getElementById(targetId);
      if (submenu) {
        submenu.classList.add('active');
      }
    });
  });

  // Back buttons
  const backBtns = document.querySelectorAll('.mobile-submenu-back');
  backBtns.forEach(btn => {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      const submenu = this.closest('.mobile-submenu');
      if (submenu) {
        submenu.classList.remove('active');
      }
    });
  });

  const submenuCloseBtns = document.querySelectorAll('.mobile-submenu-close');
  submenuCloseBtns.forEach(btn => {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      const activeSubmenus = document.querySelectorAll('.mobile-submenu.active');
      activeSubmenus.forEach(submenu => {
        submenu.classList.remove('active');
      });
      const menu = document.getElementById('mobileMenu');
      if (menu) {
        menu.classList.remove('open');
      }
      document.body.classList.remove('mobile-menu-open');
    });
  });
}

function toggleMobileMenu() {
  const menu = document.getElementById("mobileMenu");
  const body = document.body;
  
  if (menu) {
    menu.classList.toggle("open");
    body.classList.toggle("mobile-menu-open");
    
    // Close all submenus when closing main menu
    if (!menu.classList.contains("open")) {
      const activeSubmenus = document.querySelectorAll('.mobile-submenu.active');
      activeSubmenus.forEach(submenu => {
        submenu.classList.remove('active');
      });
    }
  }
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initMobileMenu);
} else {
  initMobileMenu();
}

function copyToClipboard() {
  const textToCopy = window.location.href; // Or any custom link
  navigator.clipboard.writeText(textToCopy).then(() => {
    const tooltip = document.getElementById("copyTooltip");
    tooltip.textContent = "Copied to Clipboard";
    tooltip.style.color = "#3b82f6";
    setTimeout(() => {
      tooltip.textContent = "Click to Copy";
    }, 2000);
  });
}


jQuery(document).ready(function ($) {
  let isDragging = false;

  if ($(".slick-carousel").length) {
    $(".slick-carousel")
      .on("mousedown touchstart", function () {
        isDragging = false;
      })
      .on("mousemove touchmove", function () {
        isDragging = true;
      });

    $(".slick-carousel").slick({
      slidesToShow: 1,
      slidesToScroll: 1,
      infinite: true,
      arrows: false,
      dots: true,
      responsive: [
        {
          breakpoint: 5840, // true 4K UHD
          settings: {
            slidesToShow: 4.5,
          },
        },
        {
          breakpoint: 3840, // true 4K UHD
          settings: {
            slidesToShow: 3.35,
          },
        },
        {
          breakpoint: 2560, // 2K–4K wide monitors
          settings: {
            slidesToShow: 2.35,
          },
        },
        {
          breakpoint: 1920, // Full HD desktop
          settings: {
            slidesToShow: 1.66,
          },
        },
        {
          breakpoint: 1440, // laptops / mid desktops
          settings: {
            slidesToShow: 2.35,
          },
        },
        {
          breakpoint: 1024, // tablets
          settings: {
            slidesToShow: 1.65,
          },
        },
        {
          breakpoint: 600, // phones
          settings: {
            slidesToShow: 1,
          },
        },
      ],
    });

    // Prevent clicks on slides if dragging
    document.querySelectorAll(".carousel-slide").forEach(function (slide) {
      slide.style.cursor = "pointer";

      slide.addEventListener("click", function (event) {
        if (isDragging) {
          event.preventDefault();
          event.stopImmediatePropagation();
          return;
        }

        // Only go to the URL if not dragging
        if (!event.target.closest("a")) {
          const url = this.getAttribute("data-url");
          if (url) {
            window.location.href = url;
          }
        }
      });
    });
  }

  // Mobile dropdown toggle
  $(".dropdown-toggle").on("click", function (e) {
    if ($(window).width() < 992) {
      e.preventDefault();
      const $parent = $(this).parent();
      $parent.toggleClass("show");
      $parent.find(".dropdown-megamenu, .dropdown-menu").toggleClass("show");
    }
  });

  // Handle highlight when scrolling, if not found any other id keep highlight previous one, give more offset top, scroll to fast it not works
  const offsetTop = 200;

  $(window).on("scroll", function () {
    const tocLinks = $(".toc-link");
    const scrollPosition = $(this).scrollTop() + offsetTop;

    let currentIndex = -1;

    tocLinks.each(function (i) {
      const target = $($(this).attr("href"));
      if (target.length) {
        const targetPosition = target.offset().top;
        if (scrollPosition >= targetPosition) {
          currentIndex = i; // keep updating to the last matching section
        }
      }
    });

    tocLinks.removeClass("active");
    if (currentIndex >= 0) {
      tocLinks.eq(currentIndex).addClass("active");
    }
  });

  // ========================
});

