// Expose a global handler for inline onclick usage
// Usage in markup: onclick="openMenuList(this)" or onclick="openMenuList()"
function openMenuList(el) {
  try {
    var trigger =
      el ||
      (window.event && (window.event.currentTarget || window.event.target));
    if (!trigger) return false;

    // Only open the immediate next sibling if it's the target container
    var menuGroupContainer = trigger.nextElementSibling;
    if (
      !menuGroupContainer ||
      !menuGroupContainer.classList ||
      !menuGroupContainer.classList.contains("menu-group-container")
    ) {
      return false;
    }

    // Close others
    document
      .querySelectorAll(".menu-group-container.open")
      .forEach(function (c) {
        if (c !== menuGroupContainer) c.classList.remove("open");
      });
    // Toggle target
    menuGroupContainer.classList.toggle("open");
  } catch (e) {
    // noop
  }
  return false;
}

// Make available on window for inline handlers
window.openMenuList = openMenuList;

// Close handler for back buttons inside mobile menu
function closeMenuGroup(el) {
  try {
    var trigger =
      el ||
      (window.event && (window.event.currentTarget || window.event.target));
    var container =
      trigger && trigger.closest
        ? trigger.closest(".menu-group-container")
        : null;
    if (container && container.classList.contains("open")) {
      container.classList.remove("open");
    } else {
      // Fallback: close any open container
      document
        .querySelectorAll(".menu-group-container.open")
        .forEach(function (c) {
          c.classList.remove("open");
        });
    }
  } catch (e) {
    // noop
  }
  return false;
}
window.closeMenuGroup = closeMenuGroup;

function antomCleanContactLinks() {
  const cleanContactUrl = "https://www.antom.com/cn/contact-us";

  document.querySelectorAll('a[href*="www.antom.com/cn/contact-us"]').forEach(function (link) {
    if (link.getAttribute("href") !== cleanContactUrl) {
      link.setAttribute("href", cleanContactUrl);
    }
  });
}

document.addEventListener("DOMContentLoaded", function () {
  antomCleanContactLinks();

  document.addEventListener("click", function (event) {
    const link = event.target.closest('a[href*="www.antom.com/cn/contact-us"]');
    if (link) {
      link.setAttribute("href", "https://www.antom.com/cn/contact-us");
    }
  }, true);

  const observer = new MutationObserver(antomCleanContactLinks);
  observer.observe(document.documentElement, {
    childList: true,
    subtree: true,
    attributes: true,
    attributeFilter: ["href"]
  });

  window.addEventListener("load", antomCleanContactLinks);
  setTimeout(antomCleanContactLinks, 500);
  setTimeout(antomCleanContactLinks, 1500);
});

document.addEventListener("DOMContentLoaded", function () {
  const promo = document.getElementById("sticky-promo");
  if (!promo) return;

  const showAfterSel = promo.getAttribute("data-show-after") || ".main-content";
  const hideAfterSel = promo.getAttribute("data-hide-after");
  const targetSel =
    promo.getAttribute("data-scroll-target") || "#chat-with-experts";
  const positionAnchorSel = promo.getAttribute("data-position-anchor");
  const GAP = 16;

  const positionEl =
    (positionAnchorSel ? document.querySelector(positionAnchorSel) : null) ||
    document.getElementById("blog-col") ||
    document.querySelector(".main-content") ||
    promo.parentElement;

  function positionPromo() {
    if (!positionEl) return;
    const r = positionEl.getBoundingClientRect();
    const w = promo.offsetWidth || 200;
    promo.style.left = Math.max(8, window.pageXOffset + r.left - w - GAP) + "px";
  }

  function updateVisibility() {
    const showAfterEl = document.querySelector(showAfterSel);
    const hideAfterEl = hideAfterSel ? document.querySelector(hideAfterSel) : null;

    if (!showAfterEl) {
      promo.style.visibility = "hidden";
      promo.style.opacity = "0";
      promo.style.pointerEvents = "none";
      return;
    }

    const showPoint = showAfterEl.getBoundingClientRect().top + window.scrollY;
    const hidePoint = hideAfterEl
      ? hideAfterEl.getBoundingClientRect().top + window.scrollY
      : Number.POSITIVE_INFINITY;
    const y = window.scrollY;
    const withinRange =
      y > showPoint && y + window.innerHeight * 0.25 < hidePoint;

    promo.style.visibility = withinRange ? "visible" : "hidden";
    promo.style.opacity = withinRange ? "1" : "0";
    promo.style.pointerEvents = withinRange ? "auto" : "none";
  }

  promo.addEventListener("click", function (e) {
    const link = e.target.closest(".sticky-cta");
    if (!link) return;
    const target = document.querySelector(targetSel);
    if (target) {
      e.preventDefault();
      target.scrollIntoView({ behavior: "smooth", block: "start" });
    }
  });

  function tick() {
    positionPromo();
    updateVisibility();
  }

  tick();
  window.addEventListener("scroll", tick, { passive: true });
  window.addEventListener("resize", tick);
  window.addEventListener("orientationchange", tick);
  window.addEventListener("load", tick);
  setTimeout(tick, 300);
  setTimeout(tick, 1200);
});
