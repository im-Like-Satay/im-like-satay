document.addEventListener("DOMContentLoaded",function(){const t=window.jQuery,e=t(".country-selector-view .dropdown-menu").data("main-site"),o=t(".country-selector-view .dropdown-item[item-country='"+e+"']");o.addClass("active"),t(".country-selector-view .dropdown-toggle p").text(o.first().find("p").text());const r=o.first().find("img").attr("data-lazy-src")||o.first().find("img").attr("src");t(".country-selector-view .dropdown-toggle .btn-img").attr("src",r),t(".country-selector-view .dropdown-toggle .btn-img").attr("alt",o.first().find("p").text()),t(".country-selector-view img").attr("loading","lazy"),t(".country-selector-view .dropdown-toggle .btn-img").show()});